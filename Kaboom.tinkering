<!DOCTYPE html>
<html>
<head>
    <title>Mouse vs Cat: Best of Three</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://unpkg.com/kaboom@3000.1.17/dist/kaboom.js"></script>
    <style>
        body { margin: 0; background: #000; overflow: hidden; }
        .ui { position: absolute; top: 0; width: 100%; height: 100%; display: flex; flex-direction: column; align-items: center; justify-content: center; background: rgba(0,0,0,0.9); color: white; font-family: sans-serif; z-index: 10; }
        .btn-game { width: 280px; font-weight: bold; padding: 15px; }
    </style>
</head>
<body>

    <div id="menu" class="ui">
        <h1>MOUSE vs CAT</h1>
        <button class="btn btn-light btn-game mb-3" onclick="startSolo()">SOLO MODE</button>
        <button class="btn btn-light btn-game" onclick="startMulti()">MULTIPLAYER MODE</button>
    </div>

    <div id="reset-ui" class="ui" style="display:none">
        <h1 id="win-text">MATCH OVER</h1>
        <button class="btn btn-warning btn-game" onclick="location.reload()">RESTART GAME</button>
    </div>

<script>
    kaboom({ width: 1200, height: 600, background: [20, 20, 20] });

    loadSprite("mouse", "mouse.png");
    loadSprite("cat", "cat.jpg");

    function startSolo() {
        document.getElementById("menu").style.display = "none";
        go("game", true);
    }

    function startMulti() {
        document.getElementById("menu").style.display = "none";
        go("game", false);
    }

    scene("game", (isSolo) => {
        setGravity(1600);
        camPos(1250, 300);
        camScale(0.45);

        // --- MATCH SCORES ---
        let mouseMatchPoints = 0;
        let catMatchPoints = 0;

        const scoreText = add([
            text("MATCH: 0 - 0", { size: 32 }),
            pos(width() / 2, 20),
            fixed(),
            anchor("center")
        ]);

        // --- 1. YOUR ORIGINAL MAP ---
        addLevel([
            "                                                                                ",
            "         ====                                ====                               ",
            "                             $$                                     $    f    ",
            "  ====                       ======                                  ====  ==== ",
            "=====      ^^      ====                ^^            ====        ^^        =====",
            "================================================================================",
        ], {
            tileWidth: 32,
            tileHeight: 32,
            tiles: {
                "=": () => [rect(32, 200), area(), body({ isStatic: true }), color(80, 80, 80), "wall"],
                "$": () => [rect(16, 16), area(), color(255, 215, 0), anchor("center"), "coin"],
                "^": () => [rect(32, 16), area(), color(255, 0, 0), anchor("bot"), "hazard", { speed: 120 }],
                "f": () => {
                    if (isSolo) {
                        return [rect(20, 100), area(), color(0, 100, 255), anchor("bot"), "flag"];
                    } else {
                        return [];
                    }
                }
            }
        });

        // --- 2. SETUP PLAYERS ---
        const p1 = add([
            sprite("mouse"),
            pos(150, 100),
            area(),
            body(),
            scale(0.08),
            "mouse",
            { hp: 100, isInvincible: false }
        ]);
        const hp1 = add([rect(200, 20), pos(20, 40), color(0, 255, 0), fixed()]);

        let p2 = null;
        let hp2 = null;

        if (isSolo == false) {
            p2 = add([
                sprite("cat"),
                pos(2100, 100),
                area(),
                body(),
                scale(0.35),
                "cat",
                { hp: 100, isInvincible: false }
            ]);
            hp2 = add([rect(200, 20), pos(980, 40), color(255, 0, 0), fixed()]);
        }

        // --- 3. HELPER FUNCTIONS ---
        function spawnSparkles(position) {
            for (let i = 0; i < 8; i++) {
                add([
                    rect(4, 4), pos(position), color(255, 215, 0),
                    move(rand(0, 360), 150), lifespan(0.5)
                ]);
            }
        }

        function resetRound() {
            p1.pos = vec2(150, 100);
            p1.hp = 100;
            p1.isInvincible = false;
            p1.opacity = 1;
            hp1.width = 200;

            if (p2) {
                p2.pos = vec2(2100, 100);
                p2.hp = 100;
                p2.isInvincible = false;
                p2.opacity = 1;
                hp2.width = 200;
            }
            scoreText.text = "MATCH: " + mouseMatchPoints + " - " + catMatchPoints;
        }

        function hurt(player, bar) {
            if (player.exists()) {
                if (player.isInvincible == true) {
                    return;
                }

                player.hp = player.hp - 20;
                bar.width = player.hp * 2;

                player.isInvincible = true;
                player.opacity = 0.5;

                if (player.hp <= 0) {
                    // Decide who gets a match point
                    if (player.is("mouse")) {
                        catMatchPoints = catMatchPoints + 1;
                    } else {
                        mouseMatchPoints = mouseMatchPoints + 1;
                    }

                    // Check for Match Win (First to 3)
                    if (mouseMatchPoints >= 3) {
                        go("win", "MOUSE WINS THE MATCH!");
                    } else if (catMatchPoints >= 3) {
                        go("win", "CAT WINS THE MATCH!");
                    } else {
                        // Just a round win, reset the players
                        resetRound();
                    }
                } else {
                    wait(1, () => {
                        if (player.exists()) {
                            player.isInvincible = false;
                            player.opacity = 1;
                        }
                    });
                }
            }
        }

        // --- 4. CONTROLS ---
        onKeyDown("a", () => { if(p1.exists()) p1.move(-400, 0); });
        onKeyDown("d", () => { if(p1.exists()) p1.move(400, 0); });
        onKeyPress("w", () => { if (p1.exists() && p1.isGrounded()) p1.jump(800); });
        onKeyPress("x", () => {
            if(p1.exists()) {
                add([rect(20, 10), pos(p1.pos.add(20, 20)), color(255, 255, 255), area(), move(RIGHT, 1000), "bullet", { target: "cat" }]);
            }
        });

        if (p2) {
            onKeyDown("left", () => { if(p2.exists()) p2.move(-400, 0); });
            onKeyDown("right", () => { if(p2.exists()) p2.move(400, 0); });
            onKeyPress("up", () => { if (p2.exists() && p2.isGrounded()) p2.jump(800); });
            onKeyPress("n", () => {
                if(p2.exists()) {
                    add([rect(20, 10), pos(p2.pos.add(20, 20)), color(255, 0, 0), area(), move(LEFT, 1000), "bullet", { target: "mouse" }]);
                }
            });
        }

        // --- 5. COLLISIONS ---
        onCollide("bullet", "wall", (b) => destroy(b));

        onCollide("bullet", "cat", (b) => {
            if (p2 && p2.exists() && b.target == "cat") {
                destroy(b);
                hurt(p2, hp2);
            }
        });

        onCollide("bullet", "mouse", (b) => {
            if (p1.exists() && b.target == "mouse") {
                destroy(b);
                hurt(p1, hp1);
            }
        });

        onCollide("mouse", "coin", (p, c) => {
            const savedPos = c.pos;
            destroy(c);
            spawnSparkles(savedPos);
        });

        onCollide("mouse", "hazard", () => {
            if(p1.exists()) hurt(p1, hp1);
        });

        if (p2) {
            onCollide("cat", "coin", (p, c) => {
                const savedPos = c.pos;
                destroy(c);
                spawnSparkles(savedPos);
            });
            onCollide("cat", "hazard", () => {
                if(p2.exists()) hurt(p2, hp2);
            });
        }

        if (isSolo) {
            p1.onCollide("flag", () => go("win", "MOUSE ESCAPED!"));
        }

        // --- 6. LOGIC UPDATES ---
        onUpdate("hazard", (h) => {
            h.move(h.speed, 0);
            if (h.pos.x > 2400 || h.pos.x < 0) {
                h.speed = h.speed * -1;
            }
        });

        onUpdate(() => {
            if (p1.exists() && p1.pos.y > 1000) {
                // Falling counts as a round loss
                catMatchPoints = catMatchPoints + 1;
                if (catMatchPoints >= 3) {
                    go("win", "CAT WINS THE MATCH!");
                } else {
                    resetRound();
                }
            }
            if (p2 && p2.exists() && p2.pos.y > 1000) {
                mouseMatchPoints = mouseMatchPoints + 1;
                if (mouseMatchPoints >= 3) {
                    go("win", "MOUSE WINS THE MATCH!");
                } else {
                    resetRound();
                }
            }
        });
    });

    scene("win", (msg) => {
        const ui = document.getElementById("reset-ui");
        document.getElementById("win-text").innerText = msg;
        ui.style.display = "flex";
    });
</script>
</body>
</html>
